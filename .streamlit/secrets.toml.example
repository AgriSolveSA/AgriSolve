# Copy this to .streamlit/secrets.toml and fill in your values.
# Never commit secrets.toml — it is in .gitignore.

[smtp]
host     = "smtp.gmail.com"
port     = 587
user     = "your@gmail.com"
password = "your-app-password"    # Gmail App Password (not your login password)
from     = "AgriSolve SME <your@gmail.com>"
