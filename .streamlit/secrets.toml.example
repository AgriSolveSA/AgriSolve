# Copy this to .streamlit/secrets.toml and fill in your values.
# Never commit secrets.toml — it is in .gitignore.

# ── Legacy single shared password (optional, deprecated) ──────────────────
# Still works for any client not yet migrated to the [clients] table below
# — sees every vertical, same as the old single-password behaviour. Safe to
# leave unset once all real clients have their own [clients.*] entry.
# Must be a true top-level key, before any [table] header in this file —
# TOML attaches bare keys to whichever table header preceded them.
dashboard_password = ""

[smtp]
host     = "smtp.gmail.com"
port     = 587
user     = "your@gmail.com"
password = "your-app-password"    # Gmail App Password (not your login password)
from     = "AgriSolve SME <your@gmail.com>"

# ── Per-client auth (recommended) ──────────────────────────────────────────
# Each client gets their own password and is restricted to their own
# vertical(s) — they no longer see all 4 verticals on login. Omit the
# "verticals" key to give a client (e.g. an internal/admin login) access to
# every vertical instead of listing them all by name.
[clients.abc_insurance]
password     = "change-me-1"
display_name = "ABC Insurance Brokers"
verticals    = ["Insurance Broker"]

[clients.xyz_accounting]
password     = "change-me-2"
display_name = "XYZ Accounting"
verticals    = ["Accounting Firm", "Construction"]
